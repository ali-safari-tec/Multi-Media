<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PersonalWinUIApp.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dll="using:MyWinUIUtilities.Tools"
    xmlns:flow="using:PersonalWinUIApp.Tools"
    xmlns:local="using:PersonalWinUIApp">
    <Application.Resources>

        <ResourceDictionary>
            
            <dll:LocalizationManager x:Key="Loc"/>
            <dll:FontManager x:Key="FontServices"/>

            <Style TargetType="ToggleSwitch">
                <Setter Property="flow:ToggleSwitchHelper.AutoReverse" Value="True"/>
            </Style>

            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <!-- Other merged dictionaries here -->

                <ResourceDictionary Source="/Resources/Styles/SettingButtonsStyle.xaml" />
                <ResourceDictionary Source="/Resources/Styles/SystemAccentManager.xaml" />

                <!-- +20 use lazy load -->

            </ResourceDictionary.MergedDictionaries>
            <!-- Other app resources here -->

        </ResourceDictionary>
    </Application.Resources>
</Application>
