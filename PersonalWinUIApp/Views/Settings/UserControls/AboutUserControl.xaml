<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PersonalWinUIApp.Views.Settings.UserControls.AboutUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PersonalWinUIApp.Views.Settings.UserControls"
    xmlns:tools="using:PersonalWinUIApp.Tools"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ItemsRepeater ItemsSource="{x:Bind VideoCardViewModels}">
        <ItemsRepeater.Layout>
            <controls:WrapLayout HorizontalSpacing="16" VerticalSpacing="16" Orientation="Horizontal"/>
        </ItemsRepeater.Layout>

        <ItemsRepeater.ItemTemplate>
            <DataTemplate x:DataType="tools:VideoCardViewModel">
                <Button MinHeight="250" MinWidth="250" MaxWidth="250" Padding="0" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" Click="Button_Click" CommandParameter="{x:Bind}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="200"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>
                        <Border Width="250" Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Center">
                            <Grid>
                                <Border CornerRadius="4,4,0,0" Margin="10">
                                    <Image Source="{x:Bind Thumbnail}" Stretch="Fill"/>
                                </Border>
                                    <Image Source="{x:Bind FormatIcon}" Stretch="Fill" Width="30" Height="30" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="5"/>
                            </Grid>
                        </Border>
                        <Grid Grid.Row="1" Padding="10" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <TextBlock Text="{x:Bind Duration}" Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>
                </Button>
            </DataTemplate>
        </ItemsRepeater.ItemTemplate>
    </ItemsRepeater>
</UserControl>
