<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="PersonalWinUIApp.Views.Settings.UserControls.LanguageUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:PersonalWinUIApp.Views.Settings.UserControls"
    xmlns:helper="using:MyWinUIUtilities.UserControls"
    xmlns:font="using:MyWinUIUtilities.Tools"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" Loaded="UserControl_Loaded" Unloaded="UserControl_Unloaded">

    <StackPanel Spacing="6">


        <Grid Margin="0,0,0,9">

            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="Time" Grid.Row="0" FontSize="{ThemeResource TitleLargeTextBlockFontSize}" FontWeight="SemiBold" font:FontScaleHelper.Enable="True" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>
            <TextBlock x:Name="Date" Grid.Row="1" FontSize="{ThemeResource BodyTextBlockFontSize}" font:FontScaleHelper.Enable="True" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>

            <Button Style="{ThemeResource DateTimePickerFlyoutButtonStyle}" HorizontalAlignment="Right" Grid.RowSpan="2" Padding="0" Click="Button_Click">
                <helper:CustomCardGrid Glyph="&#xE774;" Title="{Binding [TimeZone], Source={StaticResource Loc}}" Text="{x:Bind TimeZone}" IsTransParent="True" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>
            </Button>
        </Grid>

        <InfoBar x:Name="DirectionInfoBar" IsOpen="False" Severity="Warning" Title="{Binding [InfoBarWarning] ,Source={StaticResource Loc}}" Message="{Binding [DirectionInfoBar] ,Source={StaticResource Loc}}" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>

        <helper:CustomCardExpanderUnClickable x:Name="LanguageExpander" Text="{Binding [LanguageCustomSettingButtonText], Source={StaticResource Loc}}" Title="{Binding [LanguageCustomSettingButtonTitle], Source={StaticResource Loc}}" Glyph="&#xF87B;" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}">
            <helper:CustomCardExpanderUnClickable.OptionContent>
                <ComboBox x:Name="LanguageCombo" MinWidth="120" SelectionChanged="LanguageCombo_SelectionChanged" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}" font:FontScaleHelper.Enable="True">
                    <ComboBoxItem Tag="en" Content="{Binding [ComboBoxItemEnglishLanguage], Source={StaticResource Loc}}" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>
                    <ComboBoxItem Tag="fa" Content="{Binding [ComboBoxItemFarsiLanguage], Source={StaticResource Loc}}" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>
                </ComboBox>
            </helper:CustomCardExpanderUnClickable.OptionContent>
            <helper:CustomCardExpanderUnClickable.GridOptionContent>
                <helper:CustomCardGrid IsTransParent="True" IsIconExist="False" Text="{Binding [FlowDirectionText], Source={StaticResource Loc}}" Title="{Binding [FlowDirectionTitle], Source={StaticResource Loc}}" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}">
                    <helper:CustomCardGrid.OptionContent>
                        <ToggleSwitch x:Name="DirectionToggle" Toggled="DirectionToggle_Toggled" OnContent="{Binding [ToggleSwitchRightToLeft], Source={StaticResource Loc}}" OffContent="{Binding [ToggleSwitchLeftToRight], Source={StaticResource Loc}}" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}" font:FontScaleHelper.Enable="True"/>
                    </helper:CustomCardGrid.OptionContent>
                </helper:CustomCardGrid>
            </helper:CustomCardExpanderUnClickable.GridOptionContent>
        </helper:CustomCardExpanderUnClickable>

        <helper:CustomCardGrid Text="{Binding [RegionCustomCardGridText], Source={StaticResource Loc}}" Title="{Binding [RegionCustomCardGridTitle], Source={StaticResource Loc}}" Glyph="&#xE909;" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}">
            <helper:CustomCardGrid.OptionContent>
                <ComboBox x:Name="RegionCombo" MinWidth="120" SelectionChanged="RegionCombo_SelectionChanged" ItemsSource="{x:Bind Regions}" font:FontScaleHelper.Enable="True">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="font:RegionName">
                            <TextBlock Text="{x:Bind Name}" FontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </helper:CustomCardGrid.OptionContent>
        </helper:CustomCardGrid>

        <helper:CustomCardExpanderClickable Text="{Binding [FontFamilyCustomCardExpanderText], Source={StaticResource Loc}}" Title="{Binding [FontFamilyCustomCardExpanderTitle], Source={StaticResource Loc}}" Glyph="&#xE8D2;" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}">
            <helper:CustomCardExpanderClickable.OptionContent>
                <ComboBox x:Name="FontCombo" MinWidth="120" Grid.Row="4" ItemsSource="{x:Bind AppFonts}" SelectionChanged="ComboBox_SelectionChanged" font:FontScaleHelper.Enable="True">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="font:AppFont">
                            <TextBlock Text="{x:Bind Name}" FontFamily="{x:Bind FontFamily}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </helper:CustomCardExpanderClickable.OptionContent>
            <helper:CustomCardExpanderClickable.GridOptionContent>
                <helper:CustomCardGrid IsTransParent="True" Text="{Binding [FontScaleCustomCardGridText], Source={StaticResource Loc}}" Title="{Binding [FontScaleCustomCardGridTitle], Source={StaticResource Loc}}" Glyph="&#xE8E9;" CardFontFamily="{Binding CurrentFont, Source={StaticResource FontServices}}">
                    <helper:CustomCardGrid.OptionContent>
                        <Slider x:Name="Slider" Minimum="0.75" Maximum="1.5" StepFrequency="0.05" SmallChange="0.05" LargeChange="0.1"  Value="{x:Bind font:FontManager.Instance.FontScale, Mode=TwoWay}" MinWidth="180" MaxWidth="350" ValueChanged="Slider_ValueChanged"/>
                    </helper:CustomCardGrid.OptionContent>
                </helper:CustomCardGrid>
            </helper:CustomCardExpanderClickable.GridOptionContent>
        </helper:CustomCardExpanderClickable>
        

    </StackPanel>
</UserControl>
